# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real tokens.

# France Travail (ex-Pôle Emploi) API
# Required to scan France Travail job postings via scan.mjs.
# Register free (2 minutes) at: https://francetravail.io/data/api-v2/acces-en-2-minutes
# After registration, generate a Bearer token from your dashboard.
FRANCE_TRAVAIL_TOKEN=your_bearer_token_here
